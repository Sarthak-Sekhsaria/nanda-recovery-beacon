# NANDA Recovery Beacon -- copy to .env and fill in.
# NEVER commit a real .env. Everything here is read from the environment in production.

# --- Core ---------------------------------------------------------------------
ENVIRONMENT=development                 # development | test | production
LOG_LEVEL=INFO
# The URL agents will call. Substituted into /skill.md at serve time.
PUBLIC_BASE_URL=http://localhost:8000

# --- Database (required) ------------------------------------------------------
# Local docker-compose:
DATABASE_URL=postgresql+psycopg://beacon:beacon@localhost:5432/beacon
# Neon / Render / Supabase style URLs are normalised automatically:
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/beacon?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_STATEMENT_TIMEOUT_MS=15000

# --- Tests --------------------------------------------------------------------
# Must be PostgreSQL. Tests create and drop the schema named by TEST_DB_SCHEMA,
# so pointing this at the same database as DATABASE_URL is safe.
TEST_DATABASE_URL=postgresql+psycopg://beacon:beacon@localhost:5432/beacon
TEST_DB_SCHEMA=beacon_test

# --- Authentication -----------------------------------------------------------
# DEMO_MODE accepts unauthenticated requests and attributes them to X-Agent-Id.
# Convenient for a public demo. NEVER enable it for a deployment holding real work.
DEMO_MODE=false
DEMO_AGENT_ID=demo-agent

# --- Leases and failure detection ---------------------------------------------
DEFAULT_HEARTBEAT_TIMEOUT_SECONDS=120
MIN_HEARTBEAT_TIMEOUT_SECONDS=5
MAX_HEARTBEAT_TIMEOUT_SECONDS=86400
SUSPECT_GRACE_SECONDS=30
DEFAULT_LEASE_SECONDS=300
MIN_LEASE_SECONDS=10
MAX_LEASE_SECONDS=3600
DEFAULT_MAX_RECOVERIES=3

# --- Reaper (background failure detection) ------------------------------------
# true  -> a daemon thread in the API process sweeps every REAPER_INTERVAL_SECONDS.
# false -> run `python -m app.reaper --loop` as a separate worker process.
RUN_REAPER_IN_API=true
REAPER_INTERVAL_SECONDS=15
REAPER_BATCH_SIZE=200
OPPORTUNISTIC_SWEEP_MIN_INTERVAL_SECONDS=5

# --- Context evaluation -------------------------------------------------------
RESUMABLE_MIN_SCORE=50
SUPPORTED_CHECKPOINT_SCHEMA_VERSIONS=1.0

# --- Artifacts ----------------------------------------------------------------
STORAGE_BACKEND=none                    # none | s3
ARTIFACT_VERIFY_MAX_BYTES=26214400
ARTIFACT_VERIFY_TIMEOUT_SECONDS=10
# Leave false in production: prevents the service being used to probe internal networks.
ARTIFACT_ALLOW_PRIVATE_NETWORKS=false
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT_URL=                      # set for Cloudflare R2 / MinIO
# S3_PRESIGN_EXPIRY_SECONDS=900

# --- HTTP hardening -----------------------------------------------------------
CORS_ALLOW_ORIGINS=*                    # comma-separated; set to your dashboard origin in prod
TRUSTED_HOSTS=*                         # comma-separated; set to your domain in prod
MAX_REQUEST_BYTES=1048576
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Pagination ---------------------------------------------------------------
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# --- Dashboard (frontend/.env.local) ------------------------------------------
# The dashboard talks to the API from the server side, so the key never reaches a browser.
# BEACON_API_URL=http://localhost:8000
# BEACON_API_KEY=nrb_...
# NEXT_PUBLIC_BEACON_PUBLIC_URL=http://localhost:8000
