# Dashboard configuration. Copy to .env.local for local development.

# Where the dashboard's SERVER reaches the API. Never exposed to the browser.
BEACON_API_URL=http://localhost:8000

# Only needed when the API runs with DEMO_MODE=false.
# Mint one with:  cd backend && python -m app.cli create-key --agent-id beacon-dashboard
# BEACON_API_KEY=nrb_...

# The API URL shown to visitors (curl examples, links to /skill.md and /docs).
# Set this to the public HTTPS URL of the API in production.
NEXT_PUBLIC_BEACON_PUBLIC_URL=http://localhost:8000
